# REPI environment configuration — EXAMPLE ONLY
# Copy this file to .env and fill in real values locally.
# Never commit the actual .env file.

# --- Database (time-series store) ---
DATABASE_URL=postgresql://user:password@localhost:5432/repi
TIMESCALEDB_ENABLED=true

# --- Object storage (raw snapshots, model artefacts) ---
OBJECT_STORAGE_BUCKET=repi-artefacts
OBJECT_STORAGE_ACCESS_KEY=your_access_key_here
OBJECT_STORAGE_SECRET_KEY=your_secret_key_here

# --- Public data source connectors ---
RBZ_DATA_ENDPOINT=https://example-rbz-endpoint
ZIMSTAT_DATA_ENDPOINT=https://example-zimstat-endpoint
WORLDBANK_API_KEY=your_worldbank_api_key_here

# --- StrucLeaf platform data connectors ---
AEOS_TELEMETRY_ENDPOINT=https://example-aeos-endpoint
AEOS_API_KEY=your_aeos_api_key_here
WAZI_INFRA_ENDPOINT=https://example-wazi-endpoint
AFRIVIEW_NETWORK_ENDPOINT=https://example-afriview-endpoint

# --- LLM narrative layer ---
LLM_MODEL_PATH=./models/llama-3-8b-instruct-q4
LLM_INFERENCE_DEVICE=cuda   # cuda | cpu

# --- API layer ---
API_KEY_SALT=change_me_locally
API_RATE_LIMIT_PER_MINUTE=60

# --- General ---
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=info
